{
  "name": "gtv-desktop-remote",
  "productName": "GTV Remote",
  "version": "0.8.0",
  "description": "macOS-first desktop remote for Google TV and Android TV",
  "packageManager": "npm@11.12.1",
  "main": "dist-electron/main/main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/usrivastava92/gtv-desktop-remote.git"
  },
  "author": "",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"tsc -p tsconfig.electron.json --watch --preserveWatchOutput\" \"wait-on tcp:5173 file:dist-electron/main/main.js file:dist-electron/main/preload.js && electron .\"",
    "build": "tsc -p tsconfig.electron.json && vite build",
    "pack": "npm run build && electron-builder --dir --publish never",
    "dist:mac": "npm run build && electron-builder --mac dmg zip --publish never",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "reset:app": "node scripts/reset-app-state.mjs",
    "reset:app:dry-run": "node scripts/reset-app-state.mjs --dry-run",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{js,mjs,cjs}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,css,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "build": {
    "appId": "com.utkarsh.gtvdesktopremote",
    "productName": "GTV Remote",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "icon": "build/icon.icns",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "files": [
      "assets/**/*",
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.utilities",
      "icon": "build/icon.icns"
    },
    "publish": {
      "provider": "github",
      "releaseType": "draft",
      "tagNamePrefix": "v"
    }
  },
  "dependencies": {
    "androidtv-remote": "^1.0.10",
    "node-forge": "^1.3.1",
    "protobufjs": "^7.5.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.39.4",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^22.15.3",
    "@types/node-forge": "^1.3.14",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "electron": "^41.0.0",
    "electron-builder": "^26.0.12",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "semantic-release": "^25.0.3",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^6.3.3",
    "wait-on": "^8.0.3"
  }
}
